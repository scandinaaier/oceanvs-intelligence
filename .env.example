# --- Supabase ---
# Project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Live data APIs ---
# NewsData.io — required for live news signals (free tier at https://newsdata.io)
VITE_NEWSDATA_API_KEY=

# Open APIs (no key needed). Listed for clarity:
VITE_EXCHANGERATE_KEY=
VITE_OPEN_METEO_KEY=

# --- Formspree (landing page newsletter form) ---
# Set during build only — the static landing's FORMSPREE_ID is replaced post-build.
# Create a form at https://formspree.io with destination email hello@tauriqadams.com,
# then set VITE_FORMSPREE_ID to the ID (e.g. xpwzabcd).
VITE_FORMSPREE_ID=
